{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stock.low",
  "description": "Evento publicado cuando el stock de un item cae por debajo del threshold",
  "type": "object",
  "properties": {
    "source": {
      "type": "string",
      "const": "restaurant.stock"
    },
    "detail-type": {
      "type": "string",
      "const": "stock.low"
    },
    "detail": {
      "type": "object",
      "properties": {
        "itemId": {
          "type": "string",
          "description": "ID del item cuyo stock está bajo"
        },
        "name": {
          "type": "string",
          "description": "Nombre del item"
        },
        "currentQuantity": {
          "type": "integer",
          "description": "Cantidad actual de stock"
        },
        "threshold": {
          "type": "integer",
          "description": "Umbral mínimo de stock"
        }
      },
      "required": ["itemId", "name", "currentQuantity", "threshold"]
    }
  },
  "required": ["source", "detail-type", "detail"]
}